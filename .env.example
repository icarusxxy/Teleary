# ── Telegram Bot Configuration ────────────────────────────────────────────
# Message @BotFather on Telegram to get your bot token
BOT_TOKEN=your_telegram_bot_token

# ── Timezone ──────────────────────────────────────────────────────────────
# Used for display formatting, scheduler timing, and Docker system timezone
TIMEZONE=Asia/Taipei

# ── Database ──────────────────────────────────────────────────────────────
# Path to SQLite database file (relative to /app in Docker)
DB_PATH=data/diary.db

# ── Logging ───────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
